# Copy this file to .env.local and fill in values for local development.
# .env.local is gitignored.

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/aitek_dev"

# App
PORT=3001
APP_URL=http://localhost:3000
NODE_ENV=development

# Clerk (fill in from your Clerk dashboard — Development keys)
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Cloudflare R2 (fill in from R2 dashboard)
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=aitek-dev
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Email
RESEND_API_KEY=re_...

# Sentry (optional in dev)
SENTRY_DSN=
